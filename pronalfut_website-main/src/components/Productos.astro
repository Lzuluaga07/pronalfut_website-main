---
// EPIC 3: Definimos los productos como un arreglo para que el código sea limpio
const productos = [
  {
    nombre: "Pulpa de Fruta",
    descripcion: "100% natural, sin conservantes ni colorantes artificiales.",
    imagen: "/productos/pulpa.webp", // EPIC 2 y 4: Uso de formato .webp
  },
  {
    nombre: "Fruta Congelada",
    descripcion: "Seleccionada y procesada con los más altos estándares de calidad.",
    imagen: "/productos/congelados.webp",
  },
  {
    nombre: "Mermeladas Artesanales",
    descripcion: "El sabor auténtico de la fruta en cada bocado.",
    imagen: "/productos/mermeladas.webp",
  }
];
---

<section id="productos" class="py-16 bg-gray-50">
  <div class="container mx-auto px-6">
    <h2 class="text-3xl md:text-4xl font-bold text-center text-green-800 mb-12">
      Nuestros Productos
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {productos.map((producto) => (
        <div class="bg-white rounded-xl shadow-md overflow-hidden hover:shadow-xl transition-shadow duration-300">
          <img 
            src={producto.imagen} 
            alt={producto.nombre} 
            class="w-full h-48 object-cover"
          />
          <div class="p-6 text-center">
            <h3 class="text-xl font-semibold text-gray-800 mb-2">{producto.nombre}</h3>
            <p class="text-gray-600 mb-4">{producto.descripcion}</p>
            <button class="text-green-600 font-bold hover:text-green-700">
              Ver más →
            </button>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
