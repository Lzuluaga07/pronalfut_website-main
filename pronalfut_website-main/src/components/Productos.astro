---
// 1. Importamos el componente de React (el molde)
import ProductCard from './productcard.jsx'; 
// 2. Importamos los datos del JSON (la información)
import productosData from '../data/productos.json';
---

<section id="productos" class="py-16 bg-gray-50">
  <div class="container mx-auto px-6 max-w-6xl"> 
    <h2 class="text-3xl md:text-4xl font-bold text-center text-green-800 mb-12">
      Nuestros Productos
    </h2>

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-2 gap-12 justify-items-center">
  {
    productosData && Array.isArray(productosData) ? (
      productosData.map((producto) => (
        <ProductCard   producto={producto} client:load />
      ))
    ) : (
      <p class="text-center col-span-full">Cargando productos...</p>
    )
  }
</div>   
