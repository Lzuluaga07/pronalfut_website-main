---
// EPIC 3: Definimos los productos como un arreglo para que el código sea limpio
const productos = [
  {
    nombre: "Pulpa de Fruta",
    descripcion: "100% natural, sin conservantes ni colorantes artificiales.",
    imagen: "/images/naranja.jpg", // Asegúrate de que la ruta coincida con tu carpeta public/images
    link: "#"
  },
  {
    nombre: "Fruta Congelada",
    descripcion: "Seleccionada y procesada con los más altos estándares de calidad.",
    imagen: "/images/guanabana.jpg", // Asegúrate de que la ruta coincida con tu carpeta public/images
    link: "#"
  },
];
---

<section id="productos" class="py-16 bg-gray-50">
  <div class="container mx-auto px-6 max-w-6xl"> <h2 class="text-3xl md:text-4xl font-bold text-center text-green-800 mb-12">
      Nuestros Productos
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-2 gap-12 justify-items-center"> {productos.map((producto) => (
        <div class="bg-white rounded-2xl shadow-md overflow-hidden hover:shadow-2xl transition-all duration-300 border border-gray-100 group">
          <div class="overflow-hidden">
            <img 
              src={producto.imagen} 
              alt={producto.nombre} 
              class="w-full h-64 object-cover group-hover:scale-110 transition-transform duration-500"
            />
          </div>
          
          <div class="p-8 text-center">
            <h3 class="text-2xl font-bold text-gray-800 mb-3">{producto.nombre}</h3>
            <p class="text-gray-600 mb-6 leading-relaxed">
              {producto.descripcion}
            </p>
            <a 
              href={producto.link} 
              class="inline-flex items-center text-green-600 font-bold hover:text-green-700 transition-colors"
            >
              Ver más <span class="ml-2 transform group-hover:translate-x-2 transition-transform">→</span>
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

