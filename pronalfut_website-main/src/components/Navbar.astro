---
const {
  logoText = "Pronalfrut",
  whatsappLink = "https://wa.me/573103612190",
} = Astro.props;
---

<header class="sticky top-0 z-50 border-b border-gray-200 bg-white/90 backdrop-blur">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4">
    <a href="/" class="text-xl font-bold text-green-700">
      {logoText}
    </a>

    <nav class="hidden items-center gap-8 md:flex">
      <a href="#inicio" class="text-sm font-medium text-gray-700 transition hover:text-green-700">
        Inicio
      </a>
      <a href="#productos" class="text-sm font-medium text-gray-700 transition hover:text-green-700">
        Productos
      </a>
      <a href="#nosotros" class="text-sm font-medium text-gray-700 transition hover:text-green-700">
        Nosotros
      </a>
      <a href="#contacto" class="text-sm font-medium text-gray-700 transition hover:text-green-700">
        Contacto
      </a>
    </nav>

    <a
      href={whatsappLink}
      target="_blank"
      rel="noopener noreferrer"
      class="rounded-xl bg-green-600 px-4 py-2 text-sm font-semibold text-white transition hover:bg-green-700"
    >
      WhatsApp
    </a>
  </div>
</header>