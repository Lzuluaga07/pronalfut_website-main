---
const {
  logoText = "ALIMENTOS PRONALFRUT",
  whatsappLink = "https://wa.me/573101234567",
} = Astro.props;
---

<header class="sticky top-0 z-50 bg-white/90 backdrop-blur">
  <nav class="bg-white shadow-md w-full z-50 top-0">
    <div class="mx-auto px-4 sm:px-6">
      <div class="flex justify-between h-16 items-center">
        <div class="flex-shrink-0 flex items-center">
          <span class="pl-16 text-2xl font-bold text-green-700">Pronalfrut</span>
        </div>
        

        <div
          class="hidden md:flex space-x-8 absolute left-1/2 transform -translate-x-1/2"
        >
          <a
            href="#inicio"
            class="text-gray-700 hover:text-green-700 transition">Inicio</a
          >
          <a
            href="#nosotros"
            class="text-gray-700 hover:text-green-700 transition">Nosotros</a
          >
          <a
            href="#productos"
            class="text-gray-700 hover:text-green-700 transition">Productos</a
          >
          <a
            href="#contacto"
            class="text-gray-700 hover:text-green-700 transition">Contacto</a
          >
        </div>

        <div class="flex items-center space-x-2">
          <button id="menu-btn" class="block md:hidden text-green-700 p-1">

          </button>
        </div>
      </div>
    </div>

    <div class="flex items-center space-x-4">
          <button id="menu-btn" class="block md:hidden text-green-700">
            <svg
              class="h-8 w-8"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M4 6h16M4 12h16m-7 6h7"></path>
            </svg>
          </button>
        </div>
  </nav>

  <script>
    const btn = document.getElementById("menu-btn");
    const menu = document.getElementById("mobile-menu");
    if (btn && menu) {
      btn.addEventListener("click", () => {
        menu.classList.toggle("hidden");
      });
    }
  </script>
</header>
