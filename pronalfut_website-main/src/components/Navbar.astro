---
interface Props {
  logoText?: string;
  whatsappLink?: string;
}

const {
  logoText = "Pronalfrut",
  whatsappLink = "https://wa.me/573101234567"
} = Astro.props as Props;
---

<header class="sticky top-0 z-50 w-full bg-white shadow-md">
  <div class="max-w-7xl mx-auto px-4">
    <div class="flex justify-between items-center h-32">
      
   <div class="flex-shrink-0">
  <a href="#inicio" class="flex items-center">
  <img 
  src="/src/assets/Logo pronalfrut.png" 
  alt="Logo oficial Pronalfrut" 
  class="h-24 w-auto object-contain"
/>  
</div>   

    <button id="menu-button" class="block md:hidden text-gray-700 focus:outline-none">
        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7"></path>
        </svg>
      </button>

      <nav id="menu-items" class="hidden md:flex flex-col md:flex-row absolute md:static top-20 left-0 w-full md:w-auto bg-white md:bg-transparent p-4 md:p-0 shadow-md md:shadow-none space-y-4 md:space-y-0 md:space-x-8 z-50">
        <a href="/" class="text-gray-700 hover:text-green-600 font-medium transition-colors">Inicio</a>
        <a href="#nosotros" class="text-gray-700 hover:text-green-600 font-medium transition-colors">Nosotros</a>
        <a href="#productos" class="text-gray-700 hover:text-green-600 font-medium transition-colors">Productos</a>
        <a href="#contacto" class="text-gray-700 hover:text-green-600 font-medium transition-colors">Contacto</a>
       <div class="flex items-center gap-1 text-gray-700 font-medium ml-4 border-l pl-4 border-gray-300">
        <span class="material-symbols-outlined text-orange-600 text-[20px]">
          location_on
        </span>
        <span class="text-sm">Bogotá, Colombia</span>
      </div> 
      </nav>

      <a 
  href={whatsappLink} 
  target="_blank" 
  class="fixed bottom-6 right-6 z-50 bg-green-600 text-white p-4 rounded-full shadow-2xl hover:bg-green-700 transition-all flex items-center justify-center"
>
  <span class="font-bold">Chat</span>
</a>
        </a>
      </div>
    </div>
  </div>
</header>

<style is:global>
  html { scroll-behavior: smooth; }
</style>

<style>
  a { transition: transform 0.2s; }
  a:hover { transform: scale(1.05); }
</style>

<script>
  const menuButton = document.querySelector('#menu-button');
  const menuItems = document.querySelector('#menu-items');
const navLinks = document.querySelectorAll('#menu-items a');
  
  if (menuButton && menuItems) {
    menuButton.addEventListener('click', () => {
      menuItems.classList.toggle('hidden');
      menuItems.classList.toggle('flex');
    });

  navLinks.forEach(link => {
    link.addEventListener('click', () => {
      menuItems.classList.add('hidden'); // Asegura que se oculte
      menuItems.classList.remove('flex'); // Quita el modo visible
  }); // Este cierra el addEventListener (el paréntesis que te faltaba)
  }); // Este cierra el forEach
} // Este cierra el if principal
</script>



  
 

