---
interface Testimonial {
  quote: string;
  author: string;
  rating: number;
  image: string;
}

interface Props {
  title?: string;
  testimonials?: Testimonial[];
}

const {
  title = "Testimonios",
  testimonials = [
    {
      quote: "Alimentos SAS superó nuestras expectativas. Compramos un car...",
      author: "LOLA MILES",
      rating: 5,
      image: "/images/testimonio-1.jpg",
    },
    {
      quote: "La frescura del producto y la consistencia en cada entrega...",
      author: "JUAN PÉREZ",
      rating: 5,
      image: "/images/testimonio-2.jpg",
    },
    {
      quote: "Necesitábamos un proveedor confiable para volumen alto...",
      author: "MARÍA FERNANDA",
      rating: 5,
      image: "/images/testimonio-3.jpg",
    }
  ]
} = Astro.props;
---

<section class="relative overflow-hidden bg-[#f5f5f3] px-6 py-16 md:px-10 lg:px-16">
  <div class="mx-auto max-w-7xl">
    <h2 class="mb-10 text-center text-4xl font-extrabold tracking-tight text-slate-900 md:mb-14 md:text-6xl">
      {title}
    </h2>

    <div
      class="relative"
      data-carousel
      data-total={testimonials.length}
    >
      <div class="overflow-hidden">
        <div
          class="flex transition-transform duration-500 ease-in-out"
          data-track
        >
          {testimonials.map((item, index) => (
            <article
              class="w-full shrink-0"
              data-slide
              aria-hidden={index === 0 ? "false" : "true"}
            >
              <div class="grid items-center gap-10 lg:grid-cols-[1.05fr_0.95fr]">
                <div class="flex h-full flex-col justify-center">
                  <div class="mb-6 text-7xl leading-none text-lime-600 md:text-8xl">
                    &#8220;
                  </div>

                  <p class="max-w-sm text-xs italic leading-[1.9] text-neutral-600 md:text-[1rem]">
                    {item.quote}
                  </p>

                  <div class="mt-10">
                    <p class="text-lg font-extrabold uppercase tracking-tight text-lime-600 md:text-xl">
                      {item.author}
                    </p>

                    <div class="mt-3 flex gap-1 text-2xl text-amber-400">
                      {Array.from({ length: item.rating }).map(() => (
                        <span>★</span>
                      ))}
                    </div>
                  </div>
                </div>

                <div class="relative">
                  <img
                    src={item.image}
                    alt={`Testimonio de ${item.author}`}
                    class="h-[420px] w-full rounded-[2rem] object-cover shadow-sm md:h-[560px]"
                    loading="lazy"
                  />
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>

      <div class="mt-10 flex items-center justify-between gap-4">
        <div class="flex items-center gap-2" data-dots>
          {testimonials.map((_, index) => (
            <button
              type="button"
              class={`h-3 w-3 rounded-full transition ${
                index === 0 ? "bg-lime-600" : "bg-slate-300"
              }`}
              aria-label={`Ir al testimonio ${index + 1}`}
              data-dot={index}
            />
          ))}
        </div>

        <div class="flex items-center gap-3">
          <button
            type="button"
            class="rounded-full border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 transition hover:border-lime-600 hover:text-lime-600"
            data-prev
          >
            Anterior
          </button>

          <button
            type="button"
            class="rounded-full bg-slate-900 px-4 py-2 text-sm font-semibold text-white transition hover:bg-lime-600"
            data-next
          >
            Siguiente
          </button>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const carousels = document.querySelectorAll("[data-carousel]");

  carousels.forEach((carousel) => {
    const track = carousel.querySelector<HTMLElement>("[data-track]");
    const slides = carousel.querySelectorAll("[data-slide]");
    const dots = carousel.querySelectorAll("[data-dot]");
    const prev = carousel.querySelector("[data-prev]");
    const next = carousel.querySelector("[data-next]");
    const total = slides.length;

    let current = 0;
    let interval: number | undefined;

    const render = () => {
      if (!track) return;
      track.style.transform = `translateX(-${current * 100}%)`;

      slides.forEach((slide, index) => {
        slide.setAttribute("aria-hidden", index === current ? "false" : "true");
      });

      dots.forEach((dot, index) => {
        dot.classList.toggle("bg-lime-600", index === current);
        dot.classList.toggle("bg-slate-300", index !== current);
      });
    };

    const goTo = (index: number) => {
      current = (index + total) % total;
      render();
    };

    const startAuto = () => {
      stopAuto();
      interval = window.setInterval(() => {
        goTo(current + 1);
      }, 5000);
    };

    const stopAuto = () => {
      if (interval) clearInterval(interval);
    };

    prev?.addEventListener("click", () => {
      goTo(current - 1);
      startAuto();
    });

    next?.addEventListener("click", () => {
      goTo(current + 1);
      startAuto();
    });

    dots.forEach((dot) => {
      dot.addEventListener("click", () => {
        const index = Number(dot.getAttribute("data-dot"));
        goTo(index);
        startAuto();
      });
    });

    carousel.addEventListener("mouseenter", stopAuto);
    carousel.addEventListener("mouseleave", startAuto);

    render();
    startAuto();
  });
</script>


