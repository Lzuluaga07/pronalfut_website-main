---
interface Props {
  title: string;
  paragraph: string;
  align?: "left" | "center" | "right";
}

const { 
  title, 
  paragraph, 
  align = "center",
} = Astro.props as Props;

const alignment = {
  left: "text-left",
  center: "text-center",
  right: "text-right",
};
---

<section class="py-16 px-4 bg-white">
  <div class={`mx-auto max-w-4xl ${alignment[align]}`}>
    <h2 class="text-3xl font-bold text-green-800 md:text-5xl mb-6 tracking-tight">
      {title}
    </h2>

    {align === "center" && (
      <div class="w-20 h-1 bg-orange-500 mx-auto mb-8 rounded-full"></div>
    )}

    <p class="text-lg md:text-xl leading-relaxed text-gray-700 text-pretty">
      {paragraph}
    </p>
  </div>
</section>


