---
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import TextBlock from "../components/TextBlock.astro";
import TestimonialCarousel from "../components/TestimonialCarousel.astro";
import Hero from "../components/Hero.astro";
import Productos from "../components/Productos.astro";
import Footer from "../components/Footer.astro";

// Datos para el "Emisor"
const heroTitle = "Pulpas de Fruta 100% Naturales";
const heroSubtitle = "Sabor real y frescura del campo para tu negocio, procesado con los más altos estándares de calidad.";
const heroImage = "/images/hero-bg.webp"; // Asegúrate de que el archivo exista en public/images/


const testimonials = [
  {
    quote:
      "Alimentos Pronalfrut superó nuestras expectativas. Compramos un cargamento grande de pulpa de fruta para nuestra cadena de restaurantes, y la calidad es insuperable.",
    author: "CLIENTE SATISFECHO",
    rating: 5,
    image: "/images/testimonio-1.webp",
  },
  {
    quote:
      "La calidad del producto y la puntualidad en la entrega fueron excelentes. Nuestro negocio pudo operar con total tranquilidad gracias a su cumplimiento.",
    author: "JUAN PÉREZ",
    rating: 5,
    image: "/images/testimonio-2.webp",
  },
  {
    quote:
      "Muy buena atención y una pulpa de fruta con sabor realmente natural. Se nota el cuidado en todo el proceso.",
    author: "ANA GARCÍA",
    rating: 5,
    image: "/images/testimonio-3.webp",
  },
];
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Alimentos Pronalfrut | Pulpa de fruta 100% natural</title>
    <meta
      name="description"
      content="Pulpas de fruta 100% naturales para negocios que buscan calidad. Sin conservantes y sabor real."
    />
  </head>
 <body>
  <Navbar logoText="Pronalfrut" whatsappLink="https://wa.me/573001234567" />

  <main>
   <Hero 
  title="Alimentos Pronalfrut" 
  subtitle="Pulpa de fruta 100% natural, sabor real y frescura para tu negocio." 
  imageWebp="/images/hero-pronalfrut.jpeg"
 
/>

    <section id="nosotros" class="py-10">
      <TextBlock
        title="Nosotros"
        paragraph="Somos líderes en Colombia en el procesamiento y conservación de alimentos..."
        align="center"
      />
    </section>

    <section id="productos">
      <Productos />
    </section>

    <section id="testimonios">
      <TestimonialCarousel testimonials={testimonials} />
    </section>
  </main>

  <Footer />
</body>
</html>


